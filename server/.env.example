# 复制本文件为 .env 并按需修改。.env 已被 .gitignore 忽略，不会提交。

# 服务监听端口（站点 + AI 接口同一个端口）
PORT=8080

# AWS 区域（Bedrock 所在区）
AWS_REGION=us-west-2

# 使用哪个本地 AWS 凭证 profile（~/.aws/credentials 里的）
# 本机用专门的 bedrock profile
AWS_PROFILE=bedrock

# 文本模型（Bedrock inference profile ID）
# 主模型：原 claude-sonnet-4 / 默认调用走这里
CLAUDE_MODEL_PRIMARY=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# 副模型：原 gpt-4o-mini（双版本对比里的第二版）走更快更省的 Claude
CLAUDE_MODEL_SECONDARY=us.anthropic.claude-haiku-4-5-20251001-v1:0

# 图片模型（美术文档用，可选）。注意 Titan/Nova 可能被标记 Legacy 需先激活；
# Stability 系列通常 active。本服务对两类返回格式都做了兼容。
BEDROCK_IMAGE_MODEL=stability.stable-image-core-v1:1

# 单次回复最大 token
MAX_TOKENS=4096
