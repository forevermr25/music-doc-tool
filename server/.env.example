# 复制本文件为 .env 并按需修改。.env 已被 .gitignore 忽略，不会提交。

# 服务监听端口（站点 + AI 接口同一个端口）
PORT=8080

# AWS 区域（Bedrock 所在区）
AWS_REGION=us-west-2

# 使用哪个本地 AWS 凭证 profile（~/.aws/credentials 里的）
# 本机用专门的 bedrock profile
AWS_PROFILE=bedrock

# 文本模型（Bedrock inference profile ID）
# 当前统一使用 Claude Opus 4.8。注意 Opus 4.8 已弃用 temperature 参数，
# 服务端会自动对该模型跳过 temperature（见 server.js modelSupportsTemperature）。
CLAUDE_MODEL_PRIMARY=global.anthropic.claude-opus-4-8
CLAUDE_MODEL_SECONDARY=global.anthropic.claude-opus-4-8

# 图片模型（美术文档用，可选）。注意 Titan/Nova 可能被标记 Legacy 需先激活；
# Stability 系列通常 active。本服务对两类返回格式都做了兼容。
BEDROCK_IMAGE_MODEL=stability.stable-image-core-v1:1

# 单次回复最大 token
MAX_TOKENS=4096
